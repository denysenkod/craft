# Google OAuth credentials (Desktop app type)
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Linear OAuth credentials
# Get these from linear.app/settings/api > Create OAuth Application
# Callback URL: http://localhost:38901/oauth/callback
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Recall.ai API key (entered in Settings UI, not needed here)
# RECALL_API_KEY=
